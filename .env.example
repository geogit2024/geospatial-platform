# ─────────────────────────────────────────────
# Geospatial Platform — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Storage backend: minio (dev) | gcs (prod)
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_RAW=raw-images
STORAGE_BUCKET_PROCESSED=processed-images

# Redis (event queue)
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_UPLOADED=image:uploaded
REDIS_STREAM_PROCESSED=image:processed
REDIS_CONSUMER_GROUP=workers

# GeoServer
GEOSERVER_URL=http://geoserver:8080/geoserver
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_WORKSPACE=geoimages
# Path inside GeoServer container where processed files are accessible
GEOSERVER_DATA_DIR=/opt/geoserver_data

# Database
DATABASE_URL=postgresql+asyncpg://geo:geo@postgres:5432/geodb
DATABASE_SYNC_URL=postgresql://geo:geo@postgres:5432/geodb

# API
API_SECRET_KEY=changeme-in-production
SIGNED_URL_EXPIRY_SECONDS=3600
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Worker
WORKER_CONCURRENCY=4
GDAL_CACHEMAX=512
TARGET_CRS=EPSG:4326
