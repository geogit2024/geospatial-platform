# ─────────────────────────────────────────────
# Geospatial Platform — Environment Variables (GCP / Cloud Run)
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Storage — GCS buckets (no credentials needed: ADC via Cloud Run identity)
STORAGE_BUCKET_RAW=raw-images-geopublish
STORAGE_BUCKET_PROCESSED=imagens-processadas-geopublicas

# Redis (event queue) — use Cloud Memorystore or Upstash
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_UPLOADED=image:uploaded
REDIS_STREAM_PROCESSED=image:processed
REDIS_CONSUMER_GROUP=workers

# GeoServer
GEOSERVER_URL=http://geoserver:8080/geoserver
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_WORKSPACE=geoimages
GEOSERVER_DATA_DIR=/opt/geoserver_data

# Database — use Cloud SQL (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://geo:geo@/geodb?host=/cloudsql/geopublish:us-central1:geodb
DATABASE_SYNC_URL=postgresql://geo:geo@/geodb?host=/cloudsql/geopublish:us-central1:geodb

# API
API_SECRET_KEY=changeme-in-production
SIGNED_URL_EXPIRY_SECONDS=3600
CORS_ORIGINS=http://localhost:3000,https://SEU_FRONTEND.run.app
CORS_ORIGIN_REGEX=https://([a-zA-Z0-9-]+\.)*(arcgis\.com|arcgisonline\.com)

# Email (SMTP) - required for real invite/welcome emails
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=usuario_smtp
SMTP_PASSWORD=senha_smtp
SMTP_FROM_EMAIL=no-reply@seudominio.com
SMTP_FROM_NAME=GeoPublish
SMTP_USE_TLS=true
SMTP_USE_SSL=false
APP_PUBLIC_URL=https://SEU_FRONTEND.run.app

# Worker
WORKER_CONCURRENCY=4
WORKER_HEARTBEAT_SECONDS=20
WORKER_ENABLE_STALLED_RECOVERY=true
WORKER_RECOVER_PROCESSING_MINUTES=30
WORKER_RECOVER_PUBLISHING_MINUTES=20
REDIS_CLAIM_MIN_IDLE_MS=900000
REDIS_CLAIM_BATCH=10
REDIS_CLAIM_INTERVAL_SECONDS=30
GDAL_CACHEMAX=512
TARGET_CRS=EPSG:4326

# GCP Project (informativo — não usado em código, ADC resolve automaticamente)
GCP_PROJECT_ID=geopublish

# Billing / Metrics costs
# configured: usa custos fixos abaixo
# gcp_billing_export: usa custos reais da tabela de export do Billing no BigQuery
BILLING_COST_SOURCE=configured
BILLING_CURRENCY=BRL
COST_PER_GB_MONTH=0.15
COST_PER_PROCESS=0.05
COST_PER_DOWNLOAD=0.01

# GCP Project e tabela de export de faturamento (BigQuery)
GCP_PROJECT_ID=geopublish
GCP_BILLING_EXPORT_PROJECT=geopublish
GCP_BILLING_EXPORT_TABLE=geopublish.billing_export.gcp_billing_export_resource_v1_XXXXXX_XXXXXX_XXXXXX
