# ─────────────────────────────────────────────
# Geospatial Platform — Environment Variables (GCP / Cloud Run)
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Storage — GCS buckets (no credentials needed: ADC via Cloud Run identity)
STORAGE_BUCKET_RAW=raw-images-geopublish
STORAGE_BUCKET_PROCESSED=imagens-processadas-geopublicas

# Redis (event queue) — use Cloud Memorystore or Upstash
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_UPLOADED=image:uploaded
REDIS_STREAM_PROCESSED=image:processed
REDIS_CONSUMER_GROUP=workers

# GeoServer
GEOSERVER_URL=http://geoserver:8080/geoserver
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_WORKSPACE=geoimages
GEOSERVER_DATA_DIR=/opt/geoserver_data
VECTOR_DEFAULT_DATASTORE=postgis_ds
POSTGIS_SCHEMA=public

# Database — use Cloud SQL (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://geo:geo@/geodb?host=/cloudsql/geopublish:us-central1:geodb
DATABASE_SYNC_URL=postgresql://geo:geo@/geodb?host=/cloudsql/geopublish:us-central1:geodb

# API
API_SECRET_KEY=changeme-in-production
SIGNED_URL_EXPIRY_SECONDS=3600
UPLOAD_MAX_SIZE_MB=2048
CORS_ORIGINS=http://localhost:3000,https://SEU_FRONTEND.run.app
CORS_ORIGIN_REGEX=https://([a-zA-Z0-9-]+\.)*(arcgis\.com|arcgisonline\.com)

# Upload cost estimate (pre-process simulation)
UPLOAD_COST_ESTIMATE_ENABLED_DEFAULT=false
UPLOAD_COST_ESTIMATE_FORCE_ENABLED=false
UPLOAD_COST_ESTIMATE_FEATURE_KEY=upload_cost_estimate_v1
UPLOAD_COST_ESTIMATE_SESSION_TTL_MINUTES=120
UPLOAD_COST_ESTIMATE_TEMP_BUCKET=
UPLOAD_COST_ESTIMATE_TEMP_PREFIX=tmp/cost-estimate
UPLOAD_COST_ESTIMATE_TEMP_SIGNED_URL_EXPIRY_SECONDS=900
UPLOAD_COST_ESTIMATE_DEFAULT_MONTHLY_DOWNLOADS=100
UPLOAD_COST_ESTIMATE_DEFAULT_AVG_DOWNLOAD_SIZE_RATIO=0.35
UPLOAD_COST_ESTIMATE_DEFAULT_PROCESSED_SIZE_RATIO_RASTER=0.65
UPLOAD_COST_ESTIMATE_DEFAULT_PROCESSED_SIZE_RATIO_VECTOR=0.35
UPLOAD_COST_ESTIMATE_DEFAULT_PROCESSING_BASE_UNITS=1.0
UPLOAD_COST_ESTIMATE_DEFAULT_PROCESSING_UNITS_PER_GB_RASTER=2.0
UPLOAD_COST_ESTIMATE_DEFAULT_PROCESSING_UNITS_PER_GB_VECTOR=1.2
UPLOAD_COST_ESTIMATE_DEFAULT_UNCERTAINTY_MIN_FACTOR=0.7
UPLOAD_COST_ESTIMATE_DEFAULT_UNCERTAINTY_MAX_FACTOR=1.4

# Email (SMTP) - required for real invite/welcome emails
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=usuario_smtp
SMTP_PASSWORD=senha_smtp
SMTP_FROM_EMAIL=no-reply@seudominio.com
SMTP_FROM_NAME=GeoPublish
SMTP_USE_TLS=true
SMTP_USE_SSL=false
APP_PUBLIC_URL=https://SEU_FRONTEND.run.app

# Worker
WORKER_CONCURRENCY=4
WORKER_HEARTBEAT_SECONDS=20
WORKER_ENABLE_STALLED_RECOVERY=true
WORKER_RECOVER_PROCESSING_MINUTES=30
WORKER_RECOVER_PUBLISHING_MINUTES=20
WORKER_MODE=service
WORKER_ENABLE_HEALTH_SERVER=true
WORKER_ENABLE_STARTUP_SYNC=true
WORKER_JOB_IDLE_EXIT_SECONDS=45
WORKER_JOB_MAX_RUNTIME_SECONDS=540
WORKER_JOB_BLOCK_MS=4000
WORKER_JOB_BATCH_COUNT=8
REDIS_CLAIM_MIN_IDLE_MS=900000
REDIS_CLAIM_BATCH=10
REDIS_CLAIM_INTERVAL_SECONDS=30
GDAL_CACHEMAX=512
TARGET_CRS=EPSG:4326
VECTOR_WORKSPACE_PREFIX=user
VECTOR_PROCESSING_TIMEOUT_SECONDS=900
VECTOR_PUBLISH_TIMEOUT_SECONDS=120
VECTOR_SIMPLIFY_TOLERANCE=0.0
VECTOR_SIMPLIFY_MIN_FEATURES=5000

# GCP Project (informativo — não usado em código, ADC resolve automaticamente)
GCP_PROJECT_ID=geopublish

# Worker on-demand trigger — API starts the Cloud Run Job after queueing work
WORKER_JOB_TRIGGER_ENABLED=true
WORKER_JOB_PROJECT_ID=geopublish
WORKER_JOB_REGION=us-central1
WORKER_JOB_NAME=geopublish-worker-job
WORKER_JOB_TRIGGER_LOCK_ENABLED=true
WORKER_JOB_TRIGGER_LOCK_KEY=worker:cloud-run-job:trigger-lock
WORKER_JOB_TRIGGER_LOCK_TTL_SECONDS=60

# Billing / Metrics costs
# configured: usa custos fixos abaixo
# gcp_billing_export: usa custos reais da tabela de export do Billing no BigQuery
BILLING_COST_SOURCE=configured
BILLING_CURRENCY=BRL
COST_PER_GB_MONTH=0.15
COST_PER_PROCESS=0.05
COST_PER_DOWNLOAD=0.01
METRICS_STORAGE_CACHE_TTL_SECONDS=300
METRICS_COST_CACHE_TTL_SECONDS=1800
OGC_ACCESS_LOG_BATCH_SIZE=200
OGC_ACCESS_LOG_FLUSH_INTERVAL_SECONDS=5
OGC_ACCESS_LOG_SAMPLE_RATE_HIGH_VOLUME=0.1

# GCP Project e tabela de export de faturamento (BigQuery)
GCP_PROJECT_ID=geopublish
GCP_BILLING_EXPORT_PROJECT=geopublish
GCP_BILLING_EXPORT_TABLE=geopublish.billing_export.gcp_billing_export_resource_v1_XXXXXX_XXXXXX_XXXXXX
