# GeoPublish PROD
# Use este arquivo como contrato de configuracao. Segredos devem ficar no
# Secret Manager e ser injetados no Cloud Run, nao commitados em .env real.

ENVIRONMENT=prod
GCP_PROJECT_ID=geopublish
GOOGLE_CLOUD_PROJECT=geopublish
GCP_REGION=us-central1

# Database / queue
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_SYNC_URL=postgresql://USER:PASSWORD@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
REDIS_URL=redis://REDIS_HOST:6379/0
REDIS_STREAM_UPLOADED=image:uploaded
REDIS_STREAM_PROCESSED=image:processed
REDIS_CONSUMER_GROUP=workers

# GCS
STORAGE_BUCKET_RAW=geopublish-prod-raw
STORAGE_BUCKET_PROCESSED=geopublish-prod-processed
SIGNED_URL_EXPIRY_SECONDS=3600
UPLOAD_MAX_SIZE_MB=2048

# GeoServer
GEOSERVER_URL=https://geoserver-internal.example.com/geoserver
GEOSERVER_PUBLIC_URL=https://geoserver.example.com/geoserver
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=secret-manager:geoserver-admin-password
GEOSERVER_WORKSPACE=geoimages
VECTOR_DEFAULT_DATASTORE=postgis_ds
POSTGIS_SCHEMA=public

# API / frontend
API_SECRET_KEY=secret-manager:api-secret-key
CORS_ORIGINS=https://app.example.com
CORS_ORIGIN_REGEX=https://([a-zA-Z0-9-]+\.)*(arcgis\.com|arcgisonline\.com)
APP_PUBLIC_URL=https://app.example.com

# Worker service/job
WORKER_MODE=service
WORKER_CONCURRENCY=4
WORKER_HEARTBEAT_SECONDS=20
WORKER_ENABLE_STALLED_RECOVERY=true
WORKER_ENABLE_HEALTH_SERVER=true
WORKER_ENABLE_STARTUP_SYNC=true
WORKER_JOB_TRIGGER_ENABLED=true
WORKER_JOB_PROJECT_ID=geopublish
WORKER_JOB_REGION=us-central1
WORKER_JOB_NAME=geopublish-worker-job
WORKER_JOB_TRIGGER_LOCK_ENABLED=true
WORKER_JOB_TRIGGER_LOCK_KEY=worker:cloud-run-job:trigger-lock
WORKER_JOB_TRIGGER_LOCK_TTL_SECONDS=60
WORKER_JOB_IDLE_EXIT_SECONDS=45
WORKER_JOB_MAX_RUNTIME_SECONDS=540
WORKER_JOB_BLOCK_MS=4000
WORKER_JOB_BATCH_COUNT=8
GDAL_CACHEMAX=512
TARGET_CRS=EPSG:3857
RASTER_TARGET_CRS=EPSG:3857
VECTOR_WORKSPACE_PREFIX=user
VECTOR_PROCESSING_TIMEOUT_SECONDS=900
VECTOR_PUBLISH_TIMEOUT_SECONDS=120

# Metrics / costs
BILLING_COST_SOURCE=gcp_billing_export
BILLING_CURRENCY=BRL
GCP_BILLING_EXPORT_PROJECT=geopublish
GCP_BILLING_EXPORT_TABLE=geopublish.billing_export.gcp_billing_export_resource_v1_XXXXXX_XXXXXX_XXXXXX
METRICS_STORAGE_CACHE_TTL_SECONDS=300
METRICS_COST_CACHE_TTL_SECONDS=1800
OGC_ACCESS_LOG_BATCH_SIZE=200
OGC_ACCESS_LOG_FLUSH_INTERVAL_SECONDS=5
OGC_ACCESS_LOG_SAMPLE_RATE_HIGH_VOLUME=0.1

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=secret-manager:smtp-user
SMTP_PASSWORD=secret-manager:smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=GeoPublish
SMTP_USE_TLS=true
SMTP_USE_SSL=false
