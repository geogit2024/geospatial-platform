# GeoPublish DEV local
# Copie para env/.env.dev e ajuste os buckets GCS.

ENVIRONMENT=dev
GCP_PROJECT_ID=geopublish
GOOGLE_CLOUD_PROJECT=geopublish
# Opcional quando o ADC padrao for credencial de usuario:
# GOOGLE_APPLICATION_CREDENTIALS=/home/appuser/.config/gcloud/legacy_credentials/upload@funrio.iam.gserviceaccount.com/adc.json

# Database / queue
DATABASE_URL=postgresql+asyncpg://geo:geo@postgres:5432/geodb
DATABASE_SYNC_URL=postgresql://geo:geo@postgres:5432/geodb
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_UPLOADED=image:uploaded
REDIS_STREAM_PROCESSED=image:processed
REDIS_CONSUMER_GROUP=workers

# GCS - recomendado tambem em DEV para manter paridade com PROD
STORAGE_BUCKET_RAW=geopublish-dev-raw
STORAGE_BUCKET_PROCESSED=geopublish-dev-processed
SIGNED_URL_EXPIRY_SECONDS=3600
UPLOAD_MAX_SIZE_MB=2048

# GeoServer local
GEOSERVER_URL=http://geoserver:8080/geoserver
GEOSERVER_PUBLIC_URL=http://localhost:8080/geoserver
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_WORKSPACE=geoimages
GEOSERVER_DATA_DIR=/opt/geoserver_data
VECTOR_DEFAULT_DATASTORE=postgis_ds
POSTGIS_SCHEMA=public

# API / frontend
API_SECRET_KEY=changeme-dev
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080
CORS_ORIGIN_REGEX=https://([a-zA-Z0-9-]+\.)*(arcgis\.com|arcgisonline\.com)
APP_PUBLIC_URL=http://localhost:3000

# Worker
WORKER_MODE=service
WORKER_CONCURRENCY=4
WORKER_HEARTBEAT_SECONDS=20
WORKER_ENABLE_STALLED_RECOVERY=true
WORKER_ENABLE_HEALTH_SERVER=true
WORKER_ENABLE_STARTUP_SYNC=true
WORKER_JOB_TRIGGER_ENABLED=false
GDAL_CACHEMAX=512
TARGET_CRS=EPSG:3857
RASTER_TARGET_CRS=EPSG:3857
VECTOR_WORKSPACE_PREFIX=user
VECTOR_PROCESSING_TIMEOUT_SECONDS=900
VECTOR_PUBLISH_TIMEOUT_SECONDS=120

# Metrics / costs
BILLING_COST_SOURCE=configured
BILLING_CURRENCY=BRL
COST_PER_GB_MONTH=0.15
COST_PER_PROCESS=0.05
COST_PER_DOWNLOAD=0.01
METRICS_STORAGE_CACHE_TTL_SECONDS=300
METRICS_COST_CACHE_TTL_SECONDS=1800
OGC_ACCESS_LOG_BATCH_SIZE=200
OGC_ACCESS_LOG_FLUSH_INTERVAL_SECONDS=5
OGC_ACCESS_LOG_SAMPLE_RATE_HIGH_VOLUME=0.1

# Optional SMTP for local tests
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=GeoPublish
SMTP_USE_TLS=true
SMTP_USE_SSL=false
